# GraphQL Gateway Environment Variables
# Copy to .env and fill in values.

GATEWAY_SERVICE_NAME=graphql-gateway
GATEWAY_PORT=4000
GATEWAY_DEBUG=false

# Internal service URLs
GATEWAY_IDENTITY_SERVICE_URL=http://localhost:8001
GATEWAY_FLEET_SERVICE_URL=http://localhost:8002
GATEWAY_MATCHING_SERVICE_URL=http://localhost:8003
GATEWAY_FINTRACK_SERVICE_URL=http://localhost:8004
GATEWAY_AGENT_SERVICE_URL=http://localhost:8005

# CORS (configure per environment)
GATEWAY_CORS_ORIGINS=*
