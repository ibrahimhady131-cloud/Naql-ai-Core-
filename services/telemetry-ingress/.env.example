# Telemetry Ingress Environment Variables
# Copy to .env and fill in values. Prefix: TELEMETRY_

TELEMETRY_SERVICE_NAME=telemetry-ingress
TELEMETRY_SERVICE_PORT=8006
TELEMETRY_DEBUG=false

# MQTT (EMQX)
TELEMETRY_MQTT_BROKER_HOST=localhost
TELEMETRY_MQTT_BROKER_PORT=1883
TELEMETRY_MQTT_USERNAME=
TELEMETRY_MQTT_PASSWORD=
TELEMETRY_MQTT_CLIENT_ID=naql-telemetry-ingress

# MQTT Topics
TELEMETRY_MQTT_TOPIC_POSITION=naql/truck/+/position
TELEMETRY_MQTT_TOPIC_TELEMETRY=naql/truck/+/telemetry
TELEMETRY_MQTT_TOPIC_ALERT=naql/truck/+/alert

# TimescaleDB
TELEMETRY_TIMESCALE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/naql_telemetry

# Redis (Real-time geo index)
TELEMETRY_REDIS_URL=redis://localhost:6379/4

# NATS
TELEMETRY_NATS_URL=nats://localhost:4222

# Processing
TELEMETRY_BATCH_SIZE=100
TELEMETRY_FLUSH_INTERVAL_SEC=5
TELEMETRY_GEOFENCE_CHECK_ENABLED=true
