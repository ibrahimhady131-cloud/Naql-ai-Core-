# Fleet Service Environment Variables
# Copy to .env and fill in values. Prefix: FLEET_

FLEET_SERVICE_NAME=fleet-service
FLEET_SERVICE_PORT=8002
FLEET_GRPC_PORT=50052
FLEET_DEBUG=false

# CockroachDB
FLEET_DATABASE_URL=postgresql+asyncpg://root@localhost:26257/naql_fleet

# NATS
FLEET_NATS_URL=nats://localhost:4222

# Redis
FLEET_REDIS_URL=redis://localhost:6379/1

# Telemetry
FLEET_TELEMETRY_BATCH_SIZE=100
FLEET_POSITION_UPDATE_INTERVAL_SEC=5
