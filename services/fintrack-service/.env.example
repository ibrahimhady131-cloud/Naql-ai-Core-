# FinTrack Service Environment Variables
# Copy to .env and fill in values. Prefix: FINTRACK_

FINTRACK_SERVICE_NAME=fintrack-service
FINTRACK_SERVICE_PORT=8004
FINTRACK_GRPC_PORT=50054
FINTRACK_DEBUG=false

# CockroachDB
FINTRACK_DATABASE_URL=postgresql+asyncpg://root@localhost:26257/naql_fintrack

# NATS
FINTRACK_NATS_URL=nats://localhost:4222

# Redis
FINTRACK_REDIS_URL=redis://localhost:6379/3

# Payment Gateways (Egyptian)
FINTRACK_FAWRY_API_KEY=
FINTRACK_FAWRY_SECRET=
FINTRACK_PAYMOB_API_KEY=
FINTRACK_PAYMOB_INTEGRATION_ID=

# Pricing
FINTRACK_SERVICE_FEE_PERCENTAGE=0.08
FINTRACK_INSURANCE_RATE_PER_KM=0.5
FINTRACK_BASE_FUEL_RATE_PER_KM=4.5
