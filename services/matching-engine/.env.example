# Matching Engine Environment Variables
# Copy to .env and fill in values. Prefix: MATCHING_

MATCHING_SERVICE_NAME=matching-engine
MATCHING_SERVICE_PORT=8003
MATCHING_GRPC_PORT=50053
MATCHING_DEBUG=false

# CockroachDB
MATCHING_DATABASE_URL=postgresql+asyncpg://root@localhost:26257/naql_matching

# NATS
MATCHING_NATS_URL=nats://localhost:4222

# Redis (Geo-spatial index)
MATCHING_REDIS_URL=redis://localhost:6379/2

# Matching parameters
MATCHING_DEFAULT_SEARCH_RADIUS_KM=20.0
MATCHING_MAX_SEARCH_RADIUS_KM=100.0
MATCHING_MAX_CANDIDATES=10
MATCHING_MATCH_TIMEOUT_SEC=120

# Scoring weights (must sum to 1.0)
MATCHING_WEIGHT_DISTANCE=0.30
MATCHING_WEIGHT_RATING=0.25
MATCHING_WEIGHT_ETA=0.25
MATCHING_WEIGHT_PRICE=0.20
