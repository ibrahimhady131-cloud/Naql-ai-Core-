# Agent Orchestrator Environment Variables
# Copy to .env and fill in values. Prefix: AGENT_

AGENT_SERVICE_NAME=agent-orchestrator
AGENT_SERVICE_PORT=8005
AGENT_GRPC_PORT=50055
AGENT_DEBUG=false

# LLM (OpenAI)
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_MODEL=gpt-4o
AGENT_OPENAI_TEMPERATURE=0.1

# Vector DB (Pinecone)
AGENT_PINECONE_API_KEY=
AGENT_PINECONE_INDEX_NAME=naql-agent-memory
AGENT_PINECONE_ENVIRONMENT=us-east-1

# Internal service URLs
AGENT_IDENTITY_SERVICE_URL=http://localhost:8001
AGENT_FLEET_SERVICE_URL=http://localhost:8002
AGENT_MATCHING_SERVICE_URL=http://localhost:8003
AGENT_FINTRACK_SERVICE_URL=http://localhost:8004

# NATS
AGENT_NATS_URL=nats://localhost:4222

# Agent behavior
AGENT_MAX_PLANNING_STEPS=10
AGENT_AGENT_TIMEOUT_SEC=60
AGENT_ENABLE_SENTINEL=true
