# Identity Service Environment Variables
# Copy to .env and fill in values. Prefix: IDENTITY_

IDENTITY_SERVICE_NAME=identity-service
IDENTITY_SERVICE_PORT=8001
IDENTITY_GRPC_PORT=50051
IDENTITY_DEBUG=false

# CockroachDB
IDENTITY_DATABASE_URL=postgresql+asyncpg://root@localhost:26257/naql_identity

# Auth — MUST change in production
IDENTITY_JWT_SECRET_KEY=change-me-in-production
IDENTITY_JWT_ALGORITHM=HS256
IDENTITY_ACCESS_TOKEN_EXPIRE_MINUTES=60
IDENTITY_REFRESH_TOKEN_EXPIRE_DAYS=30

# NATS
IDENTITY_NATS_URL=nats://localhost:4222

# Redis
IDENTITY_REDIS_URL=redis://localhost:6379/0
